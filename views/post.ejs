<%- include('partials/header') %>

<div class="container mt-4">
  <h2><%= post ? "Edit Post" : "Create Post" %></h2>

  <% if (errors.length > 0) { %>
    <div class="alert alert-danger"><%= errors %></div>
  <% } %>
  <form action="<%= post ? `/posts/${post._id}` : '/posts' %>" method='POST'>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="mb-3">
      <label for="title" class="form-label">Title</label>
      <input type="text" id="title" name="title" class="form-control" value="<%= post ? post.title : '' %>"
             required>
    </div>
    <div class="mb-3">
      <label for="description" class="form-label">Description</label>
      <textarea id="description" name="description" class="form-control"
                required><%= post ? post.description : '' %></textarea>
    </div>
    <button type="submit" class="btn btn-success"><%= post ? "Update Post" : "Create Post" %></button>
    <a href="/posts" class="btn btn-secondary">Cancel</a>
  </form>
</div>

<%- include('partials/footer') %>
